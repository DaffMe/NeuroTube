# ─── YouTube API ─────────────────────────────────────────────────
# Get your key at: https://console.cloud.google.com/
YOUTUBE_API_KEY=AIzaSyA_example_key_dont_use_this

# ─── PostgreSQL (Database) ───────────────────────────────────────
# These credentials are used for the local Docker container
POSTGRES_USER=your_secure_user
POSTGRES_PASSWORD=your_super_secret_password
POSTGRES_DB=neurotube_db
POSTGRES_PORT=5432

# ─── Redis (Task Queue) ──────────────────────────────────────────
REDIS_PORT=6379

# ─── Service Configuration ───────────────────────────────────────
# Default ports for the microservices
FETCHER_PORT=8080
ML_PORT=8000
FRONTEND_PORT=5173

# ─── Frontend Environment ────────────────────────────────────────
# This is required for the React app to communicate with the backend
VITE_API_BASE_URL=http://localhost:8080
